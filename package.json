{
  "name": "xml-to-excel-converter",
  "version": "1.0.7",
  "description": "Converts XML files from xmlDosyaları directory to Excel files in excelDosyaları directory",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "compile": "bun build src/index.ts --compile --outfile dist/xml-to-excel",
    "compile:win": "bun build src/index.ts --compile --target windows --outfile dist/xml-to-excel.exe",
    "compile:linux": "bun build src/index.ts --compile --target linux --outfile dist/xml-to-excel",
    "compile:mac": "bun build src/index.ts --compile --target macos --outfile dist/xml-to-excel",
    "compile:all": "bun run compile:win && bun run compile:linux && bun run compile:mac"
  },
  "keywords": [
    "xml",
    "excel",
    "converter",
    "fast-xml-parser",
    "exceljs"
  ],
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^4.5.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "bun-types": "^1.3.10",
    "typescript": "^5.6.3"
  }
}
